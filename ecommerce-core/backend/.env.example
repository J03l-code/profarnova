# PROFARNOVA Backend Environment Variables Example

# Server Port (Passenger handles this dynamically on cPanel, but standard for local development)
PORT=5000

# Environment Mode
NODE_ENV=development

# Database Connection (MySQL/MariaDB - optimized for cPanel)
DB_HOST=localhost
DB_USER=your_cpanel_db_username
DB_PASSWORD=your_cpanel_db_password
DB_NAME=your_cpanel_db_name
DB_PORT=3306

# JWT Secret Key for token encoding/decoding
JWT_SECRET=profarnova_super_secure_jwt_token_secret_key_change_me
